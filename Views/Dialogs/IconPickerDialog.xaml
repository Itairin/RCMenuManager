<Window x:Class="RCMenuManager.Views.Dialogs.IconPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择图标" Width="640" Height="480"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FontFamily="Segoe UI, Microsoft YaHei UI, sans-serif" FontSize="13">
    <DockPanel Margin="12">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <Button x:Name="BrowseButton" Content="浏览…" Width="80" Click="BrowseButton_Click" DockPanel.Dock="Right" Margin="6,0,0,0" />
            <TextBox x:Name="PathBox" KeyDown="PathBox_KeyDown" />
        </DockPanel>
        <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <Button x:Name="OkButton" Content="使用所选" Width="100" Click="OkButton_Click" DockPanel.Dock="Right" Margin="6,0,0,0" IsDefault="True" />
            <Button x:Name="CancelButton" Content="取消" Width="80" Click="CancelButton_Click" DockPanel.Dock="Right" />
            <TextBlock x:Name="StatusText" Foreground="#5F6B7A" VerticalAlignment="Center" />
        </DockPanel>
        <ListBox x:Name="IconsList" SelectionChanged="IconsList_SelectionChanged">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Margin="4" Padding="6" BorderBrush="#E1E3E8" BorderThickness="1" CornerRadius="4">
                        <StackPanel Width="56">
                            <Image Source="{Binding Bitmap}" Width="32" Height="32" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding Index}" HorizontalAlignment="Center" Foreground="#5F6B7A" FontSize="11" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
