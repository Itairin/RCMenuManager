<Window x:Class="RCMenuManager.Views.Dialogs.IconPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择图标" Width="680" Height="500"
        Background="{StaticResource WindowBackground}"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FontFamily="Segoe UI Variable, Segoe UI, Microsoft YaHei UI, sans-serif" FontSize="13">
    <DockPanel Margin="16">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <Button x:Name="BrowseButton" Content="浏览…" MinWidth="88" Click="BrowseButton_Click"
                    DockPanel.Dock="Right" Margin="10,0,0,0" />
            <TextBox x:Name="PathBox" KeyDown="PathBox_KeyDown" />
        </DockPanel>
        <DockPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <Button x:Name="OkButton" Content="使用所选" MinWidth="100" Click="OkButton_Click"
                    DockPanel.Dock="Right" Margin="10,0,0,0"
                    Style="{StaticResource AccentButton}" IsDefault="True" />
            <Button x:Name="CancelButton" Content="取消" MinWidth="88" Click="CancelButton_Click"
                    DockPanel.Dock="Right" />
            <TextBlock x:Name="StatusText" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
        </DockPanel>
        <Border BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="8"
                Background="{StaticResource PanelBackground}">
            <ListBox x:Name="IconsList" BorderThickness="0" Background="Transparent"
                     SelectionChanged="IconsList_SelectionChanged"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="4" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Padding="6" CornerRadius="6"
                                            Background="Transparent"
                                            BorderBrush="Transparent" BorderThickness="1">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SubtleBackground}" />
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PanelBorder}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSubtleBrush}" />
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Width="64">
                            <Image Source="{Binding Bitmap}" Width="32" Height="32" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding Index}" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TertiaryTextBrush}" FontSize="11"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </DockPanel>
</Window>
