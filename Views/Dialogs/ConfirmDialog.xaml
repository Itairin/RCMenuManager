<Window x:Class="RCMenuManager.Views.Dialogs.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        FontFamily="Segoe UI, Microsoft YaHei UI, sans-serif" FontSize="13">
    <Border Padding="20" MinWidth="380">
        <StackPanel>
            <TextBlock x:Name="HeaderText" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock x:Name="BodyText" TextWrapping="Wrap" Margin="0,0,0,16" Foreground="#333" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="取消" Width="84" Height="28" Margin="0,0,8,0" Click="CancelButton_Click" />
                <Button x:Name="ConfirmButton" Content="确定" Width="84" Height="28" Click="ConfirmButton_Click" IsDefault="True" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
