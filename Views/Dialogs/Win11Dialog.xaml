<Window x:Class="RCMenuManager.Views.Dialogs.Win11Dialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Win11 新菜单" Width="600" Height="480"
        Background="{StaticResource WindowBackground}"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" ResizeMode="NoResize"
        FontFamily="Segoe UI Variable, Segoe UI, Microsoft YaHei UI, sans-serif" FontSize="13">
    <Border Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource InfoSubtleBrush}" CornerRadius="8" Padding="14,12">
                <StackPanel Orientation="Horizontal">
                    <Path Width="16" Height="16" Margin="0,2,12,0"
                          Stroke="{StaticResource InfoBrush}" StrokeThickness="1.4"
                          StrokeStartLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                          Data="M8,1 A7,7 0 1 0 8,15 A7,7 0 1 0 8,1 M8,5 V9 M8,11 V11.1" />
                    <TextBlock TextWrapping="Wrap" MaxWidth="500"
                               Foreground="{StaticResource TextBrush}"
                               Text="开启或关闭 Win11 新版右键菜单（显示更多选项折叠菜单），并管理被隐藏的 Block 列表。切换后需重启资源管理器才生效。" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="0,16,0,0">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsWindows11}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <ToggleButton Content="使用 Win11 新菜单"
                              IsChecked="{Binding IsNewMenuEnabled, Mode=TwoWay}"
                              HorizontalAlignment="Left"
                              Padding="18,8" />
            </StackPanel>

            <Border Grid.Row="1" Margin="0,16,0,0"
                    Background="{StaticResource SubtleBackground}" CornerRadius="8" Padding="14,12">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsWindows11}" Value="False">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="当前系统不是 Win11，本功能不可用。"
                           Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
            </Border>

            <Border Grid.Row="2" Margin="0,16,0,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource Card}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsWindows11}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <DataGrid ItemsSource="{Binding Blocks}"
                          SelectedItem="{Binding SelectedBlock, Mode=TwoWay}"
                          BorderThickness="0"
                          AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="被隐藏的 Verb" Binding="{Binding VerbName}" Width="*" />
                        <DataGridTemplateColumn Header="操作" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="移除" Padding="10,2"
                                            Command="{Binding DataContext.RemoveBlockCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Grid Grid.Row="3" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="重启资源管理器" MinWidth="140" Margin="0,0,10,0"
                        Command="{Binding RestartExplorerCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="IsEnabled" Value="True" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsWindows11}" Value="False">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Grid.Column="2" Content="关闭" MinWidth="88"
                        IsCancel="True" Click="OnCloseClick" />
            </Grid>
        </Grid>
    </Border>
</Window>
