<UserControl x:Class="RCMenuManager.Views.Controls.DetailsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RCMenuManager.ViewModels"
             xmlns:conv="clr-namespace:RCMenuManager.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisInverse" TrueValue="Collapsed" FalseValue="Visible" />
        <conv:StringNotEmptyToVisibilityConverter x:Key="StringToVis" />
        <conv:StringEqualsConverter x:Key="StringEq" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" BorderBrush="#E1E3E8" BorderThickness="0,0,0,1" Padding="12,10">
            <TextBlock Text="详情" FontWeight="SemiBold" FontSize="13" Foreground="#1F2937" />
        </Border>
        <Grid Grid.Row="1">
            <TextBlock Text="选中左侧菜单项以查看详情。"
                       Foreground="#5F6B7A" FontSize="12" Margin="14"
                       Visibility="{Binding HasSelectedItem, Converter={StaticResource BoolToVisInverse}}" />
            <ScrollViewer Padding="14" VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding HasSelectedItem, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12"
                                Visibility="{Binding EditPanel.IsEditing, Converter={StaticResource BoolToVisInverse}}">
                        <Button Content="编辑" Width="72" Height="28" Margin="0,0,8,0"
                                Command="{Binding EditCommand}" CommandParameter="{Binding SelectedItem}" />
                        <Button Content="删除" Width="72" Height="28" Margin="0,0,8,0"
                                Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedItem}" />
                        <Button Content="启用/禁用" Width="84" Height="28" Margin="0,0,8,0"
                                Command="{Binding ToggleEnabledCommand}" CommandParameter="{Binding SelectedItem}" />
                        <Button Content="新增子项" Width="84" Height="28"
                                Command="{Binding AddChildCommand}" CommandParameter="{Binding SelectedItem}"
                                Visibility="{Binding SelectedItem.CanHaveChildren, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" />
                    </StackPanel>
                    <Border Background="#FAD9D8" CornerRadius="3" Padding="8,6" Margin="0,0,0,8"
                            Visibility="{Binding EditPanel.ErrorMessage, Converter={StaticResource StringToVis}}">
                        <TextBlock Text="{Binding EditPanel.ErrorMessage}" Foreground="#9A1F1B" FontSize="12" TextWrapping="Wrap" />
                    </Border>
                    <StackPanel DataContext="{Binding SelectedItem}"
                                Visibility="{Binding DataContext.EditPanel.IsEditing, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisInverse}}">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Image Width="32" Height="32" Source="{Binding Icon}" />
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding VerbName}" Foreground="#5F6B7A" FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="命令" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,4,0,4" />
                        <Border Background="#F4F5F7" CornerRadius="4" Padding="8,6">
                            <TextBox Text="{Binding Command, Mode=OneWay}" IsReadOnly="True"
                                     BorderThickness="0" Background="Transparent"
                                     TextWrapping="Wrap" FontFamily="Consolas, monospace" />
                        </Border>

                        <StackPanel Visibility="{Binding HasEnvExpansion, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="展开后的命令" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,12,0,4" />
                            <Border Background="#F4F5F7" CornerRadius="4" Padding="8,6">
                                <TextBox Text="{Binding ExpandedCommand, Mode=OneWay}" IsReadOnly="True"
                                         BorderThickness="0" Background="Transparent"
                                         TextWrapping="Wrap" FontFamily="Consolas, monospace" />
                            </Border>
                        </StackPanel>

                        <StackPanel Visibility="{Binding MuiVerb, Converter={StaticResource StringToVis}, FallbackValue=Collapsed}">
                            <TextBlock Text="MUIVerb" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,12,0,4" />
                            <Border Background="#F4F5F7" CornerRadius="4" Padding="8,6">
                                <TextBox Text="{Binding MuiVerb, Mode=OneWay}" IsReadOnly="True"
                                         BorderThickness="0" Background="Transparent"
                                         TextWrapping="Wrap" FontFamily="Consolas, monospace" />
                            </Border>
                        </StackPanel>

                        <TextBlock Text="注册表路径" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,12,0,4" />
                        <Border Background="#F4F5F7" CornerRadius="4" Padding="8,6">
                            <TextBox Text="{Binding RegistryPath, Mode=OneWay}" IsReadOnly="True"
                                     BorderThickness="0" Background="Transparent"
                                     TextWrapping="Wrap" FontFamily="Consolas, monospace" />
                        </Border>

                        <TextBlock Text="标记" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,12,0,4" />
                        <WrapPanel>
                            <Border Background="#EEF2F8" Margin="0,0,6,6" CornerRadius="3" Padding="6,2"
                                    Visibility="{Binding IsExtended, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Extended (Shift+右键)" Foreground="#3B4A60" FontSize="11" />
                            </Border>
                            <Border Background="#FBE7B6" Margin="0,0,6,6" CornerRadius="3" Padding="6,2"
                                    Visibility="{Binding IsProgrammaticOnly, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="ProgrammaticAccessOnly" Foreground="#7A4A00" FontSize="11" />
                            </Border>
                            <Border Background="#FBE7B6" Margin="0,0,6,6" CornerRadius="3" Padding="6,2"
                                    Visibility="{Binding IsLegacyDisabled, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="LegacyDisable" Foreground="#7A4A00" FontSize="11" />
                            </Border>
                            <Border Background="#FAD9D8" Margin="0,0,6,6" CornerRadius="3" Padding="6,2"
                                    Visibility="{Binding IsSystemVerb, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="系统 Verb" Foreground="#9A1F1B" FontSize="11" />
                            </Border>
                            <Border Background="#E1F0E5" Margin="0,0,6,6" CornerRadius="3" Padding="6,2"
                                    Visibility="{Binding IsTop, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="置顶 (Position=Top)" Foreground="#1F6B3F" FontSize="11" />
                            </Border>
                            <Border Background="#E1F0E5" Margin="0,0,6,6" CornerRadius="3" Padding="6,2"
                                    Visibility="{Binding IsBottom, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="置底 (Position=Bottom)" Foreground="#1F6B3F" FontSize="11" />
                            </Border>
                            <Border Background="#F1ECFD" Margin="0,0,6,6" CornerRadius="3" Padding="6,2"
                                    Visibility="{Binding CascadingText, Converter={StaticResource StringToVis}}">
                                <TextBlock Foreground="#5B27C9" FontSize="11">
                                    <Run Text="级联 " />
                                    <Run Text="{Binding CascadingText, Mode=OneWay}" />
                                </TextBlock>
                            </Border>
                            <Border Background="#F1ECFD" Margin="0,0,6,6" CornerRadius="3" Padding="6,2">
                                <TextBlock FontSize="11" Foreground="#5B27C9">
                                    <Run Text="来源 " />
                                    <Run Text="{Binding OriginText, Mode=OneWay}" />
                                </TextBlock>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                    <Grid Visibility="{Binding EditPanel.IsEditing, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Verb" VerticalAlignment="Center" Margin="0,0,8,8" />
                        <TextBox   Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding SelectedItem.VerbName, Mode=OneWay}" IsReadOnly="True" Background="#F4F5F7" Margin="0,0,0,8" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="显示名" VerticalAlignment="Center" Margin="0,0,8,8" />
                        <TextBox   Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding EditPanel.DraftDisplayName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="命令" VerticalAlignment="Center" Margin="0,0,8,8" />
                        <TextBox   Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding EditPanel.DraftCommand, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" FontFamily="Consolas, monospace" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="图标" VerticalAlignment="Center" Margin="0,0,8,8" />
                        <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding EditPanel.DraftIcon, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,8" FontFamily="Consolas, monospace" />
                        <Button    Grid.Row="3" Grid.Column="2" Content="浏览…" Width="76" Click="BrowseIcon_Click" Margin="0,0,0,8" />
                        <CheckBox  Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Content="仅在 Shift+右键 时显示 (Extended)" IsChecked="{Binding EditPanel.DraftExtended}" Margin="0,0,0,8" />
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="位置" VerticalAlignment="Center" Margin="0,0,8,8" />
                        <StackPanel Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,8">
                            <RadioButton Content="默认" GroupName="editpos" IsChecked="{Binding EditPanel.DraftPosition, Converter={StaticResource StringEq}, ConverterParameter=Default}" Margin="0,0,12,0" />
                            <RadioButton Content="置顶" GroupName="editpos" IsChecked="{Binding EditPanel.DraftPosition, Converter={StaticResource StringEq}, ConverterParameter=Top}" Margin="0,0,12,0" />
                            <RadioButton Content="置底" GroupName="editpos" IsChecked="{Binding EditPanel.DraftPosition, Converter={StaticResource StringEq}, ConverterParameter=Bottom}" />
                        </StackPanel>
                        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Button Content="取消" Width="84" Height="28" Margin="0,0,8,0" Command="{Binding CancelEditCommand}" />
                            <Button Content="保存" Width="84" Height="28" Command="{Binding SaveEditCommand}" CommandParameter="{Binding SelectedItem}" IsDefault="True" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
