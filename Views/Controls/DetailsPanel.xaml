<UserControl x:Class="RCMenuManager.Views.Controls.DetailsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RCMenuManager.ViewModels"
             xmlns:conv="clr-namespace:RCMenuManager.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisInverse" TrueValue="Collapsed" FalseValue="Visible" />
        <conv:StringNotEmptyToVisibilityConverter x:Key="StringToVis" />
        <conv:StringEqualsConverter x:Key="StringEq" />

        <Style x:Key="FieldHeader" TargetType="TextBlock" BasedOn="{StaticResource FieldLabel}">
            <Setter Property="Margin" Value="0,14,0,6" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="ReadOnlyValueBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SubtleBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="FlagBadge" TargetType="Border" BasedOn="{StaticResource Badge}">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,6,6" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource SectionDivider}" Padding="14,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Path Width="14" Height="14"
                      Stroke="{StaticResource MutedTextBrush}" StrokeThickness="1.3"
                      StrokeStartLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                      Data="M3,2 H11 L13,4 V13 H3 Z M5,5 H11 M5,8 H11 M5,11 H9" />
                <TextBlock Text="详情" Style="{StaticResource TitleText}" Margin="8,0,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding HasSelectedItem, Converter={StaticResource BoolToVisInverse}}">
                <Path Width="32" Height="32"
                      Stroke="{StaticResource TertiaryTextBrush}" StrokeThickness="1.4"
                      StrokeStartLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                      Data="M6,6 H26 V26 H6 Z M11,12 H21 M11,16 H21 M11,20 H17" />
                <TextBlock Text="选中左侧菜单项查看详情" Margin="0,12,0,0"
                           Foreground="{StaticResource MutedTextBrush}" FontSize="13" />
            </StackPanel>
            <ScrollViewer Padding="16,12,16,16" VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding HasSelectedItem, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <!-- Action bar (non-editing mode) -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                Visibility="{Binding EditPanel.IsEditing, Converter={StaticResource BoolToVisInverse}}">
                        <Button Style="{StaticResource AccentButton}" MinWidth="80"
                                Command="{Binding EditCommand}" CommandParameter="{Binding SelectedItem}"
                                Margin="0,0,8,0" ToolTip="编辑该菜单项">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="12" Height="12"
                                      Stroke="{StaticResource OnAccentBrush}" StrokeThickness="1.4"
                                      StrokeStartLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                      Data="M2,10 L8,4 L10,6 L4,12 H2 Z M8,4 L9,3 L11,5 L10,6" />
                                <TextBlock Text="编辑" Margin="6,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button MinWidth="80"
                                Command="{Binding ToggleEnabledCommand}" CommandParameter="{Binding SelectedItem}"
                                Margin="0,0,8,0" ToolTip="启用 / 禁用此菜单项">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="12" Height="12"
                                      Stroke="{StaticResource MutedTextBrush}" StrokeThickness="1.4"
                                      StrokeStartLineCap="Round" Fill="Transparent"
                                      Data="M3,3 A4,4 0 1 0 9,3 M6,1 V7" />
                                <TextBlock Text="启停" Margin="6,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button MinWidth="80"
                                Command="{Binding AddChildCommand}" CommandParameter="{Binding SelectedItem}"
                                Margin="0,0,8,0" ToolTip="为该项添加子菜单"
                                Visibility="{Binding SelectedItem.CanHaveChildren, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="10" Height="10"
                                      Stroke="{StaticResource MutedTextBrush}" StrokeThickness="1.6"
                                      StrokeStartLineCap="Round" Data="M5,1 V9 M1,5 H9" />
                                <TextBlock Text="子项" Margin="6,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource DangerButton}" MinWidth="64"
                                Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedItem}"
                                ToolTip="删除该菜单项">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="11" Height="12"
                                      Stroke="{StaticResource DangerBrush}" StrokeThickness="1.4"
                                      StrokeStartLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                      Data="M2,3 H9 M4,3 V2 H7 V3 M3,3 V11 H8 V3 M5,5 V9 M6.5,5 V9" />
                                <TextBlock Text="删除" Margin="6,0,0,0" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Border Background="{StaticResource DangerSubtleBrush}" CornerRadius="6"
                            Padding="10,8" Margin="0,0,0,8"
                            Visibility="{Binding EditPanel.ErrorMessage, Converter={StaticResource StringToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="14" Height="14"
                                  Stroke="{StaticResource DangerBrush}" StrokeThickness="1.4"
                                  StrokeStartLineCap="Round" Fill="Transparent"
                                  Data="M7,1 A6,6 0 1 0 7,13 A6,6 0 1 0 7,1 M7,4 V8 M7,10 V10.1"
                                  VerticalAlignment="Center" />
                            <TextBlock Margin="8,0,0,0" Text="{Binding EditPanel.ErrorMessage}"
                                       Foreground="#9A1F1B" FontSize="12" TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <!-- View mode -->
                    <StackPanel DataContext="{Binding SelectedItem}"
                                Visibility="{Binding DataContext.EditPanel.IsEditing, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisInverse}}">
                        <Border CornerRadius="8" Background="{StaticResource PanelMutedBackground}"
                                BorderBrush="{StaticResource PanelBorder}" BorderThickness="1"
                                Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="40" Height="40"
                                        Background="{StaticResource PanelBackground}"
                                        BorderBrush="{StaticResource PanelBorder}" BorderThickness="1"
                                        CornerRadius="6">
                                    <Image Width="24" Height="24" Source="{Binding Icon}" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding VerbName}" Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Text="命令" Style="{StaticResource FieldHeader}" />
                        <TextBox Style="{StaticResource ReadOnlyValueBox}" Text="{Binding Command, Mode=OneWay}" />

                        <StackPanel Visibility="{Binding HasEnvExpansion, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="展开后的命令" Style="{StaticResource FieldHeader}" />
                            <TextBox Style="{StaticResource ReadOnlyValueBox}" Text="{Binding ExpandedCommand, Mode=OneWay}" />
                        </StackPanel>

                        <StackPanel Visibility="{Binding MuiVerb, Converter={StaticResource StringToVis}, FallbackValue=Collapsed}">
                            <TextBlock Text="MUIVerb" Style="{StaticResource FieldHeader}" />
                            <TextBox Style="{StaticResource ReadOnlyValueBox}" Text="{Binding MuiVerb, Mode=OneWay}" />
                        </StackPanel>

                        <TextBlock Text="注册表路径" Style="{StaticResource FieldHeader}" />
                        <TextBox Style="{StaticResource ReadOnlyValueBox}" Text="{Binding RegistryPath, Mode=OneWay}" />

                        <TextBlock Text="标记" Style="{StaticResource FieldHeader}" />
                        <WrapPanel>
                            <Border Style="{StaticResource FlagBadge}" Background="{StaticResource SubtleBackground}"
                                    Visibility="{Binding IsExtended, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Extended (Shift+右键)" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                            </Border>
                            <Border Style="{StaticResource FlagBadge}" Background="{StaticResource WarnSubtleBrush}"
                                    Visibility="{Binding IsProgrammaticOnly, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="ProgrammaticAccessOnly" Foreground="{StaticResource WarnBrush}" FontSize="11" />
                            </Border>
                            <Border Style="{StaticResource FlagBadge}" Background="{StaticResource WarnSubtleBrush}"
                                    Visibility="{Binding IsLegacyDisabled, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="LegacyDisable" Foreground="{StaticResource WarnBrush}" FontSize="11" />
                            </Border>
                            <Border Style="{StaticResource FlagBadge}" Background="{StaticResource DangerSubtleBrush}"
                                    Visibility="{Binding IsSystemVerb, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="系统 Verb" Foreground="{StaticResource DangerBrush}" FontSize="11" />
                            </Border>
                            <Border Style="{StaticResource FlagBadge}" Background="{StaticResource SuccessSubtleBrush}"
                                    Visibility="{Binding IsTop, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="置顶" Foreground="{StaticResource SuccessBrush}" FontSize="11" />
                            </Border>
                            <Border Style="{StaticResource FlagBadge}" Background="{StaticResource SuccessSubtleBrush}"
                                    Visibility="{Binding IsBottom, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="置底" Foreground="{StaticResource SuccessBrush}" FontSize="11" />
                            </Border>
                            <Border Style="{StaticResource FlagBadge}" Background="{StaticResource InfoSubtleBrush}"
                                    Visibility="{Binding CascadingText, Converter={StaticResource StringToVis}}">
                                <TextBlock Foreground="{StaticResource InfoBrush}" FontSize="11">
                                    <Run Text="级联 " />
                                    <Run Text="{Binding CascadingText, Mode=OneWay}" />
                                </TextBlock>
                            </Border>
                            <Border Style="{StaticResource FlagBadge}" Background="{StaticResource InfoSubtleBrush}">
                                <TextBlock FontSize="11" Foreground="{StaticResource InfoBrush}">
                                    <Run Text="来源 " />
                                    <Run Text="{Binding OriginText, Mode=OneWay}" />
                                </TextBlock>
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <!-- Edit mode -->
                    <Grid Visibility="{Binding EditPanel.IsEditing, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="84" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Verb" Style="{StaticResource FieldLabel}" Margin="0,0,12,10" />
                        <TextBox   Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                   Text="{Binding SelectedItem.VerbName, Mode=OneWay}"
                                   IsReadOnly="True" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="显示名" Style="{StaticResource FieldLabel}" Margin="0,0,12,10" />
                        <TextBox   Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                   Text="{Binding EditPanel.DraftDisplayName, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="0,0,0,10" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="命令" Style="{StaticResource FieldLabel}" Margin="0,0,12,10" />
                        <TextBox   Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                   Text="{Binding EditPanel.DraftCommand, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="0,0,0,10"
                                   FontFamily="Cascadia Mono, Consolas, monospace" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="图标" Style="{StaticResource FieldLabel}" Margin="0,0,12,10" />
                        <TextBox   Grid.Row="3" Grid.Column="1"
                                   Text="{Binding EditPanel.DraftIcon, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="0,0,8,10" FontFamily="Cascadia Mono, Consolas, monospace" />
                        <Button    Grid.Row="3" Grid.Column="2" Content="浏览…" MinWidth="84" Click="BrowseIcon_Click" Margin="0,0,0,10" />
                        <CheckBox  Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                                   Content="仅在 Shift+右键 时显示 (Extended)"
                                   IsChecked="{Binding EditPanel.DraftExtended}" Margin="0,0,0,12" />
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="位置" Style="{StaticResource FieldLabel}" Margin="0,0,12,10" />
                        <StackPanel Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,10">
                            <RadioButton Content="默认" GroupName="editpos"
                                         IsChecked="{Binding EditPanel.DraftPosition, Converter={StaticResource StringEq}, ConverterParameter=Default}"
                                         Margin="0,0,16,0" />
                            <RadioButton Content="置顶" GroupName="editpos"
                                         IsChecked="{Binding EditPanel.DraftPosition, Converter={StaticResource StringEq}, ConverterParameter=Top}"
                                         Margin="0,0,16,0" />
                            <RadioButton Content="置底" GroupName="editpos"
                                         IsChecked="{Binding EditPanel.DraftPosition, Converter={StaticResource StringEq}, ConverterParameter=Bottom}" />
                        </StackPanel>
                        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3"
                                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Content="取消" MinWidth="92" Margin="0,0,10,0" Command="{Binding CancelEditCommand}" />
                            <Button Content="保存" Style="{StaticResource AccentButton}" MinWidth="92"
                                    Command="{Binding SaveEditCommand}" CommandParameter="{Binding SelectedItem}" IsDefault="True" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>

