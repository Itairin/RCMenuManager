<UserControl x:Class="RCMenuManager.Views.Controls.ContextMenuPreview"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:RCMenuManager.Converters">
    <UserControl.Resources>
        <conv:CollectionHasItemsToVisibilityConverter x:Key="ListHasItemsToVis" />
        <conv:CollectionHasItemsToVisibilityConverter x:Key="ListEmptyToVis" TrueValue="Visible" FalseValue="Collapsed" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource SectionDivider}" Padding="14,10">
            <StackPanel Orientation="Horizontal">
                <Path Width="14" Height="14"
                      Stroke="{StaticResource MutedTextBrush}" StrokeThickness="1.3"
                      StrokeStartLineCap="Round" StrokeLineJoin="Round"
                      Data="M2,2 H10 V6 H8 L6,8 L4,6 H2 Z M2,9 H12 V13 H2 Z"
                      VerticalAlignment="Center" />
                <TextBlock Margin="8,0,0,0" Foreground="{StaticResource MutedTextBrush}" FontSize="12" VerticalAlignment="Center">
                    <Run Text="目标：" />
                    <Run Text="{Binding SelectedScope.Label, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                </TextBlock>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" x:Name="PreviewSurface" Background="Transparent"
              PreviewMouseRightButtonDown="OnPreviewSurfaceRightClick">
            <Border Margin="24" Padding="28,22" CornerRadius="10"
                    BorderBrush="{StaticResource PanelBorder}" BorderThickness="1"
                    Background="{StaticResource PanelMutedBackground}"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    SnapsToDevicePixels="True"
                    Visibility="{Binding MenuItems, Converter={StaticResource ListEmptyToVis}}">
                <StackPanel HorizontalAlignment="Center">
                    <Path Width="36" Height="36"
                          Stroke="{StaticResource TertiaryTextBrush}" StrokeThickness="1.4"
                          StrokeStartLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                          Data="M6,4 H30 V32 H6 Z M10,10 H26 M10,16 H26 M10,22 H22" />
                    <TextBlock Text="该作用域暂无菜单项"
                               Margin="0,12,0,0" Foreground="{StaticResource MutedTextBrush}" FontSize="13"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="切换作用域或新增菜单项后即可在此预览"
                               Margin="0,4,0,0" Foreground="{StaticResource TertiaryTextBrush}" FontSize="11"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
            <Border Margin="24" Padding="28,22" CornerRadius="10"
                    BorderBrush="{StaticResource PanelBorder}" BorderThickness="1"
                    Background="{StaticResource PanelBackground}"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    SnapsToDevicePixels="True"
                    Visibility="{Binding MenuItems, Converter={StaticResource ListHasItemsToVis}}">
                <StackPanel MaxWidth="380" HorizontalAlignment="Center">
                    <Border Width="48" Height="48" CornerRadius="24"
                            Background="{StaticResource AccentSubtleBrush}"
                            HorizontalAlignment="Center">
                        <Path Width="24" Height="24"
                              Stroke="{StaticResource AccentBrush}" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                              Data="M5,4 H19 V20 H5 Z M9,9 H15 M9,13 H15 M9,17 H13"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="右键预览当前作用域的菜单"
                               Margin="0,14,0,0" Style="{StaticResource TitleText}"
                               HorizontalAlignment="Center" TextAlignment="Center" />
                    <TextBlock Margin="0,8,0,0" Style="{StaticResource MutedText}"
                               TextAlignment="Center" TextWrapping="Wrap">
                        <Run Text="在预览区任意位置" />
                        <Run Text="右键" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                        <Run Text="即可看到当前作用域下的全部菜单项" />
                    </TextBlock>
                    <TextBlock Margin="0,6,0,0" Style="{StaticResource MutedText}"
                               TextAlignment="Center" TextWrapping="Wrap">
                        <Run Text="选中后右侧详情可" />
                        <Run Text="查看 / 编辑 / 删除 / 启停" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                        <Run Text="（Extended 项以 Shift 徽标标出）" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
