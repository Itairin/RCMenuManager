<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Palette tuned for Win11 light theme; we keep it neutral so it reads well in both. -->
    <SolidColorBrush x:Key="WindowBackground" Color="#F4F5F7" />
    <SolidColorBrush x:Key="PanelBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PanelBorder" Color="#E1E3E8" />
    <SolidColorBrush x:Key="AccentBrush" Color="#0F62FE" />
    <SolidColorBrush x:Key="MutedText" Color="#5F6B7A" />
    <SolidColorBrush x:Key="DangerBrush" Color="#C9211E" />
    <SolidColorBrush x:Key="WarnBrush" Color="#9A6700" />
    <SolidColorBrush x:Key="OkBrush" Color="#1F7A3A" />

    <Style TargetType="TextBlock" x:Key="HeaderText">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#1F2937" />
    </Style>

    <Style TargetType="TextBlock" x:Key="MutedText">
        <Setter Property="Foreground" Value="{StaticResource MutedText}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style TargetType="Border" x:Key="Card">
        <Setter Property="Background" Value="{StaticResource PanelBackground}" />
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

</ResourceDictionary>
