<Window x:Class="RCMenuManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:RCMenuManager.Views.Controls"
        Title="RCMenuManager"
        Width="1180" Height="720"
        MinWidth="900" MinHeight="560"
        Background="{StaticResource WindowBackground}"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        FontFamily="Segoe UI Variable, Segoe UI, Microsoft YaHei UI, sans-serif"
        FontSize="13"
        AllowDrop="True"
        DragEnter="OnWindowDragEnter"
        DragOver="OnWindowDragOver"
        DragLeave="OnWindowDragLeave"
        Drop="OnWindowDrop">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Card}">
            <c:ScopeBar />
        </Border>

        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="380" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="1.3*" MinWidth="340" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}">
                <TabControl Background="Transparent" BorderThickness="0" Padding="0">
                    <TabItem Header="列表">
                        <c:MenuTreeView />
                    </TabItem>
                    <TabItem Header="预览">
                        <c:ContextMenuPreview />
                    </TabItem>
                </TabControl>
            </Border>

            <GridSplitter Grid.Column="1" Width="10" HorizontalAlignment="Stretch" />

            <Border Grid.Column="2" Style="{StaticResource Card}">
                <c:DetailsPanel />
            </Border>
        </Grid>

        <!-- DragDrop overlay -->
        <Border Grid.RowSpan="2"
                IsHitTestVisible="False"
                Background="#E62563EB"
                BorderBrush="#1E40AF" BorderThickness="2"
                CornerRadius="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDragOver}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Path Width="64" Height="64"
                      Stroke="White" StrokeThickness="2.4"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                      Fill="Transparent"
                      Data="M8,12 H56 V52 H8 Z M32,42 V18 M22,28 L32,18 L42,28"
                      SnapsToDevicePixels="True" />
                <TextBlock Text="拖入文件 / 文件夹 / 驱动器"
                           Margin="0,16,0,0"
                           Foreground="White" FontSize="20" FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="自动识别对应的右键菜单作用域"
                           Margin="0,4,0,0"
                           Foreground="#DBE3FF" FontSize="13"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
